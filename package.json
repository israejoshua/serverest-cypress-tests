{
  "name": "serverest-cypress-tests",
  "version": "1.0.0",
  "description": "Automação de testes E2E e de API para a aplicação ServeRest usando Cypress e JavaScript",
  "keywords": [
    "cypress",
    "e2e-testing",
    "api-testing",
    "serverest",
    "qa"
  ],
  "author": "Israel Joshua",
  "license": "MIT",
  "scripts": {
    "test": "cypress run",
    "test:api": "cypress run --spec cypress/e2e/api/**/*.cy.js",
    "test:web": "cypress run --spec cypress/e2e/web/**/*.cy.js",
    "open": "cypress open",
    "lint": "eslint cypress --ext .js",
    "lint:fix": "eslint cypress --ext .js --fix",
    "format": "prettier --write \"cypress/**/*.{js,json}\" \"*.{js,json}\"",
    "report:merge": "mochawesome-merge \"cypress/reports/mocha/*.json\" > cypress/reports/mochawesome.json && marge cypress/reports/mochawesome.json -o cypress/reports/html -f index --inline"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.3.0",
    "cypress": "^13.16.1",
    "cypress-multi-reporters": "^1.6.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-cypress": "^3.6.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "prettier": "^3.4.2"
  }
}
